# Copy this file to .env.local.properties and fill your local secrets.
# This file is loaded automatically in dev mode via application-dev.yml
# and .env.local.properties is ignored by git.

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com
